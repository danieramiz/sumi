<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sumi_widget_background"
    android:clipChildren="true">

    <ImageView
        android:id="@+id/widget_medium_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Cover"
        android:visibility="visible" />

    <FrameLayout
        android:id="@+id/widget_medium_gradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/sumi_widget_gradient_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/widget_medium_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue Reading"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:id="@+id/widget_medium_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Manga"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_medium_chapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ch. 0"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:text="|"
                android:textColor="#3DFFFFFF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_medium_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0% caught up"
                android:textColor="#FF4F6D"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_medium_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:progressDrawable="@drawable/sumi_widget_progress_drawable"
            android:max="100"
            android:progress="0" />

    </LinearLayout>

</FrameLayout>
